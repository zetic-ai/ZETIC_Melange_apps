<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light, action-bar-free shell. The launch window background is the app's cream canvas
         (#F4F3EE) so it matches the programmatic Compose UI (the app is forced light). -->
    <style name="Theme.Brew" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/canvas</item>
        <item name="android:statusBarColor">@color/canvas</item>
        <item name="android:navigationBarColor">@color/canvas</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
